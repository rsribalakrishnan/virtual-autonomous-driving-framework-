<?xml version="1.0"?>
<robot name="smart_car">

  <!-- =========================
       CHASSIS
       ========================= -->
  <link name="chassis">
    <!-- Visuals -->
    <visual>
      <origin xyz="0 0 0.4" rpy="0 0 0"/>
      <geometry><box size="2.0 4.0 0.8"/></geometry>
      <material name="blue"><color rgba="0.2 0.4 0.9 1.0"/></material>
    </visual>
    <visual>
      <origin xyz="0 0 1.0" rpy="0 0 0"/>
      <geometry><box size="1.6 2.5 0.4"/></geometry>
      <material name="dark"><color rgba="0.1 0.1 0.1 1.0"/></material>
    </visual>

    <!-- Collision -->
    <collision>
      <origin xyz="0 0 0.4" rpy="0 0 0"/>
      <geometry><box size="2.0 4.0 0.8"/></geometry>
    </collision>

    <!-- Inertial -->
    <inertial>
      <origin xyz="0 0 0.5" rpy="0 0 0"/>
      <mass value="120.0"/>
      <inertia ixx="80.0" ixy="0.0" ixz="0.0"
               iyy="25.0" iyz="0.0"
               izz="95.0"/>
    </inertial>
  </link>

  <!-- =========================
       LIDAR
       ========================= -->
  <link name="lidar">
    <visual>
      <geometry><cylinder radius="0.3" length="0.3"/></geometry>
      <material name="red"><color rgba="1.0 0.0 0.0 1.0"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.3" length="0.3"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.02" ixy="0" ixz="0"
               iyy="0.02" iyz="0"
               izz="0.02"/>
    </inertial>
  </link>

  <joint name="lidar_j" type="fixed">
    <parent link="chassis"/>
    <child link="lidar"/>
    <origin xyz="0 0 1.3" rpy="0 0 0"/>
  </joint>

  <!-- =========================
       IN-CAR CAMERA (CORRECTED)
       ========================= -->
  <link name="camera">
    <!-- Visual: small box representing camera -->
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.08 0.10 0.05"/></geometry>
      <material name="black_cam"><color rgba="0.1 0.1 0.1 1.0"/></material>
    </visual>
    
    <!-- Collision: required for physics engine -->
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.08 0.10 0.05"/></geometry>
    </collision>
    
    <!-- Inertial: required even for fixed joints -->
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0"
               iyy="0.0001" iyz="0"
               izz="0.0001"/>
    </inertial>
  </link>

  <!-- Camera joint: positioned for driver's view -->
  <joint name="camera_j" type="fixed">
    <parent link="chassis"/>
    <child link="camera"/>
    <!-- Centered, forward in cabin, at eye height -->
    <origin xyz="0.0 0.9 1.05" rpy="0 0 0"/>
  </joint>

  <!-- =========================
       FRONT STEERING KNUCKLES
       ========================= -->
  <link name="knuckle_fl">
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.01" ixy="0" ixz="0"
               iyy="0.01" iyz="0"
               izz="0.01"/>
    </inertial>
  </link>

  <link name="knuckle_fr">
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.01" ixy="0" ixz="0"
               iyy="0.01" iyz="0"
               izz="0.01"/>
    </inertial>
  </link>

  <!-- =========================
       WHEELS
       ========================= -->
  <link name="wheel_fl">
    <visual>
      <origin xyz="0 0 0" rpy="0 1.57 0"/>
      <geometry><cylinder radius="0.4" length="0.3"/></geometry>
      <material name="blk"><color rgba="0.1 0.1 0.1 1"/></material>
    </visual>
    <visual>
      <origin xyz="0 0.1 0" rpy="0 0 0"/>
      <geometry><box size="0.7 0.1 0.1"/></geometry>
      <material name="white"><color rgba="1 1 1 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 1.57 0"/>
      <geometry><cylinder radius="0.4" length="0.3"/></geometry>
    </collision>
    <inertial>
      <mass value="8.0"/>
      <inertia ixx="0.20" ixy="0" ixz="0"
               iyy="0.20" iyz="0"
               izz="0.20"/>
    </inertial>
  </link>

  <link name="wheel_fr">
    <visual>
      <origin xyz="0 0 0" rpy="0 1.57 0"/>
      <geometry><cylinder radius="0.4" length="0.3"/></geometry>
      <material name="blk"><color rgba="0.1 0.1 0.1 1"/></material>
    </visual>
    <visual>
      <origin xyz="0 -0.1 0" rpy="0 0 0"/>
      <geometry><box size="0.7 0.1 0.1"/></geometry>
      <material name="white"><color rgba="1 1 1 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 1.57 0"/>
      <geometry><cylinder radius="0.4" length="0.3"/></geometry>
    </collision>
    <inertial>
      <mass value="8.0"/>
      <inertia ixx="0.20" ixy="0" ixz="0"
               iyy="0.20" iyz="0"
               izz="0.20"/>
    </inertial>
  </link>

  <link name="wheel_rl">
    <visual>
      <origin xyz="0 0 0" rpy="0 1.57 0"/>
      <geometry><cylinder radius="0.4" length="0.3"/></geometry>
      <material name="blk"><color rgba="0.1 0.1 0.1 1"/></material>
    </visual>
    <visual>
      <origin xyz="0 0.1 0" rpy="0 0 0"/>
      <geometry><box size="0.7 0.1 0.1"/></geometry>
      <material name="white"><color rgba="1 1 1 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 1.57 0"/>
      <geometry><cylinder radius="0.4" length="0.3"/></geometry>
    </collision>
    <inertial>
      <mass value="9.0"/>
      <inertia ixx="0.22" ixy="0" ixz="0"
               iyy="0.22" iyz="0"
               izz="0.22"/>
    </inertial>
  </link>

  <link name="wheel_rr">
    <visual>
      <origin xyz="0 0 0" rpy="0 1.57 0"/>
      <geometry><cylinder radius="0.4" length="0.3"/></geometry>
      <material name="blk"><color rgba="0.1 0.1 0.1 1"/></material>
    </visual>
    <visual>
      <origin xyz="0 -0.1 0" rpy="0 0 0"/>
      <geometry><box size="0.7 0.1 0.1"/></geometry>
      <material name="white"><color rgba="1 1 1 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 1.57 0"/>
      <geometry><cylinder radius="0.4" length="0.3"/></geometry>
    </collision>
    <inertial>
      <mass value="9.0"/>
      <inertia ixx="0.22" ixy="0" ixz="0"
               iyy="0.22" iyz="0"
               izz="0.22"/>
    </inertial>
  </link>

  <!-- =========================
       JOINTS
       ========================= -->

  <!-- Front steering joints: chassis -> knuckle (rotate about Z) -->
  <joint name="steer_fl" type="revolute">
    <parent link="chassis"/>
    <child link="knuckle_fl"/>
    <origin xyz="-1.1 1.6 0.0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.8" upper="0.8" effort="50" velocity="4.0"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>

  <joint name="steer_fr" type="revolute">
    <parent link="chassis"/>
    <child link="knuckle_fr"/>
    <origin xyz="1.1 1.6 0.0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.8" upper="0.8" effort="50" velocity="4.0"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>

  <!-- Front wheel spin joints: knuckle -> wheel (rotate about X) -->
  <joint name="wheel_spin_fl" type="continuous">
    <parent link="knuckle_fl"/>
    <child link="wheel_fl"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>

  <joint name="wheel_spin_fr" type="continuous">
    <parent link="knuckle_fr"/>
    <child link="wheel_fr"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>

  <!-- Rear wheel spin joints: chassis -> rear wheels (rotate about X) -->
  <joint name="roll_rl" type="continuous">
    <parent link="chassis"/>
    <child link="wheel_rl"/>
    <origin xyz="-1.1 -1.6 0.0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>

  <joint name="roll_rr" type="continuous">
    <parent link="chassis"/>
    <child link="wheel_rr"/>
    <origin xyz="1.1 -1.6 0.0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>

</robot>

































































